  private getPasswordResetEmailText(resetUrl: string, userName: string): string {
    return `
Password Reset Request - Gas Saver

Hello ${userName},

We received a request to reset your password for your Gas Saver account.

To reset your password, visit this link:
${resetUrl}

This link will expire in 1 hour and can only be used once.

If you didn't request this password reset, you can ignore this email.

---
Gas Saver
    `;
  }
