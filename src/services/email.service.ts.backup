      const verificationUrl = `${config.app.url}/api/v1/users/verify-email?token=${token}`;
      const name = username || email.split('@')[0];

      const mailOptions = {
        from: '"GasSaver" <admin@gassaver.in>',
        to: email,
        subject: 'Verify Your GasSaver Account',
        html: `
