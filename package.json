{
  "name": "energy-broker-api",
  "version": "1.0.0",
  "description": "Gas Saver API - Convert USDT deposits to ENERGY credits",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "devcoins": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "livecoins": "cross-env NODE_ENV=production ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:production": "cross-env NODE_ENV=production tsc",
    "start": "node dist/server.js",
    "start:production": "cross-env NODE_ENV=production node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "ts-node scripts/run-migration.ts",
    "migrate:deploy:prod": "NODE_ENV=production ts-node scripts/run-migration.ts",
    "migrate:production": "node scripts/prisma-production.js migrate deploy",
    "migrate:status": "node scripts/prisma-production.js migrate status",
    "migrate:status:prod": "node scripts/prisma-production.js migrate status",
    "migrate:reset": "prisma migrate reset",
    "generate": "prisma generate",
    "seed": "ts-node prisma/seed.ts",
    "seed:admin": "ts-node scripts/seed-admin.ts",
    "seed:all": "ts-node scripts/seed-all.ts",
    "seed:production": "cross-env NODE_ENV=production ts-node scripts/seed-all.ts",
    "db:setup:production": "npm run db:push:production && npm run seed:production",
    "db:push:production": "node scripts/prisma-production.js db push",
    "migrate:energy-deliveries": "ts-node scripts/migrate-energy-deliveries.ts",
    "audit:fix": "ts-node src/scripts/fix-transaction-counts.script.ts",
    "audit:fix:production": "NODE_ENV=production ts-node src/scripts/fix-transaction-counts.script.ts",
    "test:energy-reclaim": "ts-node scripts/test-energy-reclaim.ts",
    "studio": "prisma studio",
    "generate-keys": "ts-node scripts/generate-tron-keys.ts",
    "generate-system-wallet": "ts-node scripts/generate-system-wallet.ts",
    "test-env": "ts-node scripts/test-environment.ts",
    "test-env:dev": "cross-env NODE_ENV=development ts-node scripts/test-environment.ts",
    "test-env:prod": "cross-env NODE_ENV=production ts-node scripts/test-environment.ts",
    "clear-address-pool": "ts-node scripts/clear-address-pool.ts",
    "add-mainnet-addresses": "ts-node scripts/add-mainnet-addresses.ts",
    "test-energy": "ts-node scripts/test-energy-calculations.ts",
    "test-energy:dev": "cross-env NODE_ENV=development ts-node scripts/test-energy-calculations.ts",
    "test-energy:prod": "cross-env NODE_ENV=production ts-node scripts/test-energy-calculations.ts"
  },
  "keywords": [
    "tron",
    "energy",
    "broker",
    "api",
    "typescript",
    "nodejs"
  ],
  "author": "Energy Broker Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.839.0",
    "@prisma/client": "^6.12.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.3",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "tronweb": "^5.3.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "prisma": "^6.12.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
