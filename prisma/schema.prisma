generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  passwordHash            String?               @map("password_hash")
  phoneNumber             String                @unique @map("phone_number")
  isPhoneVerified         Boolean               @default(false) @map("is_phone_verified")
  otpCode                 String?               @map("otp_code")
  otpExpiry               DateTime?             @map("otp_expiry")
  credits                 Decimal               @default(0) @db.Decimal(18, 6)
  isActive                Boolean               @default(true) @map("is_active")
  isEmailVerified         Boolean               @default(false) @map("is_email_verified")
  verificationToken       String?               @map("verification_token")
  verificationTokenExpiry DateTime?             @map("verification_token_expiry")
  resetToken              String?               @map("reset_token")
  resetTokenExpiry        DateTime?             @map("reset_token_expiry")
  // Telegram authentication fields
  telegramId              BigInt?               @unique @map("telegram_id")
  telegramUsername        String?               @map("telegram_username")
  telegramFirstName       String?               @map("telegram_first_name")
  telegramLastName        String?               @map("telegram_last_name")
  telegramLanguageCode    String?               @default("en") @map("telegram_language_code")
  telegramLinkedAt        DateTime?             @map("telegram_linked_at")
  authSource              String                @default("email") @map("auth_source")
  lastLoginMethod         String?               @map("last_login_method")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  feedbacks               Feedback[]
  deposits                Deposit[]
  energyLogs              EnergyAllocationLog[]
  energyDeliveries        EnergyDelivery[]
  monitoringLogs          EnergyMonitoringLog[]
  transactions            Transaction[]
  energyStates            UserEnergyState[]
  tronAddresses           UserTronAddress[]

  @@index([telegramId])
  @@map("users")
}

model Deposit {
  id                     String          @id @default(cuid())
  userId                 String          @map("user_id")
  assignedAddressId      String?         @map("assigned_address_id")
  assignedAddress        String          @map("assigned_address")
  txHash                 String?         @unique @map("tx_hash")
  amountUsdt             Decimal?        @map("amount_usdt") @db.Decimal(18, 6)
  expectedAmount         Decimal         @map("expected_amount") @db.Decimal(18, 6)
  status                 DepositStatus   @default(PENDING)
  confirmed              Boolean         @default(false)
  blockNumber            BigInt?         @map("block_number")
  processedAt            DateTime?       @map("processed_at")
  expiresAt              DateTime        @map("expires_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  energyRecipientAddress String?         @map("energy_recipient_address")
  cancelledAt            DateTime?       @map("cancelled_at")
  cancelledBy            String?         @map("cancelled_by")
  cancellationReason     String?         @map("cancellation_reason")
  energyTransferStatus   String?         @default("PENDING") @map("energy_transfer_status")
  energyTransferTxHash   String?         @map("energy_transfer_txhash")
  energyTransferError    String?         @map("energy_transfer_error")
  energyTransferAttempts Int             @default(0) @map("energy_transfer_attempts")
  energyTransferredAt    DateTime?       @map("energy_transferred_at")
  numberOfTransactions   Int?            @map("number_of_transactions")
  calculatedUsdtAmount   Decimal?        @map("calculated_usdt_amount") @db.Decimal(18, 6)
  addressPool            AddressPool?    @relation(fields: [assignedAddressId], references: [id])
  user                   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  energyDelivery         EnergyDelivery?

  @@index([assignedAddress])
  @@index([expiresAt])
  @@index([status])
  @@index([energyTransferStatus])
  @@map("deposits")
}

model AddressPool {
  id                  String        @id @default(cuid())
  address             String        @unique
  privateKeyEncrypted String?       @map("private_key_encrypted")
  status              AddressStatus @default(FREE)
  assignedToDepositId String?       @map("assigned_to_deposit_id")
  assignedAt          DateTime?     @map("assigned_at")
  expiresAt           DateTime?     @map("expires_at")
  lastUsedAt          DateTime?     @map("last_used_at")
  usageCount          Int           @default(0) @map("usage_count")
  createdAt           DateTime      @default(now()) @map("created_at")
  deposits            Deposit[]

  @@index([status])
  @@index([expiresAt])
  @@index([assignedToDepositId])
  @@map("address_pool")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  type        TransactionType
  amount      Decimal           @db.Decimal(18, 6)
  txHash      String?           @map("tx_hash")
  status      TransactionStatus @default(PENDING)
  fromAddress String?           @map("from_address")
  toAddress   String?           @map("to_address")
  description String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  message   String
  rating    Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UserEnergyState {
  id                                String                @id @default(cuid())
  userId                            String
  tronAddress                       String                @unique
  currentEnergyCached               Int                   @default(0)
  lastDelegatedAmount               Int                   @default(0)
  lastDelegationTxHash              String?
  lastDelegationTime                DateTime?
  cumulativeConsumedSinceLastCharge Int                   @default(0)
  totalConsumedToday                Int                   @default(0)
  lastObservedEnergy                Int                   @default(0)
  lastUsageTime                     DateTime?
  lastPenaltyTime                   DateTime?
  lastTxCheckTimestamp              DateTime?             @map("last_tx_check_timestamp")
  inactivityHours                   Int                   @default(0)
  transactionsRemaining             Int                   @default(0)
  inactivityPenalties               Int                   @default(0)
  status                            EnergyUserStatus      @default(ACTIVE)
  createdAt                         DateTime              @default(now())
  updatedAt                         DateTime              @updatedAt
  apiErrorsCount                    Int                   @default(0) @map("api_errors_count")
  currentAllocationCharged          Int                   @default(0) @map("current_allocation_charged")
  energyHistory                     Json?                 @map("energy_history")
  lastAction                        String?               @map("last_action")
  lastActionAt                      DateTime?             @map("last_action_at")
  lastBlockchainCheck               DateTime?             @map("last_blockchain_check")
  monitoringMetadata                Json?                 @map("monitoring_metadata")
  finalReclaimCompleted             Boolean               @default(false) @map("final_reclaim_completed")
  finalReclaimAt                    DateTime?             @map("final_reclaim_at")
  logs                              EnergyAllocationLog[]
  monitoringLogs                    EnergyMonitoringLog[]
  user                              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, transactionsRemaining])
  @@index([lastBlockchainCheck])
  @@map("user_energy_state")
}

model EnergyAllocationLog {
  id                         String                 @id @default(cuid())
  userId                     String?
  tronAddress                String
  action                     EnergyAllocationAction
  requestedEnergy            Int?
  actualDelegatedEnergy      Int?
  reclaimedEnergy            Int?
  consumedEnergy             Int?
  transactionsRemainingAfter Int?
  ratioUsed                  Float?
  txHash                     String?
  reason                     String?
  createdAt                  DateTime               @default(now())
  state                      UserEnergyState        @relation(fields: [tronAddress], references: [tronAddress], onDelete: Cascade, map: "StateOnAddress")
  user                       User?                  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tronAddress])
  @@index([action])
  @@map("energy_allocation_log")
}

model Admin {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String             @map("password_hash")
  name         String?
  role         AdminRole          @default(ADMIN)
  permissions  String[]           @default([])
  isActive     Boolean            @default(true) @map("is_active")
  lastLoginAt  DateTime?          @map("last_login_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  activityLogs AdminActivityLog[]

  @@map("admins")
}

model AdminActivityLog {
  id          String   @id @default(cuid())
  adminId     String   @map("admin_id")
  adminEmail  String   @map("admin_email")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

model UserTronAddress {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  address    String
  tag        String?
  isVerified Boolean  @default(false) @map("is_verified")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([userId])
  @@map("user_tron_addresses")
}

model EnergyRate {
  id                      String   @id @default(cuid())
  energyPerTransaction    Int      @map("energy_per_transaction")
  bufferPercentage        Decimal  @map("buffer_percentage") @db.Decimal(5, 2)
  minEnergy               Int      @map("min_energy")
  maxEnergy               Int      @map("max_energy")
  oneTransactionThreshold Int      @default(65000) @map("one_transaction_threshold")
  twoTransactionThreshold Int      @default(131000) @map("two_transaction_threshold")
  description             String?
  updatedBy               String   @map("updated_by")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([isActive, createdAt(sort: Desc)])
  @@map("energy_rates")
}

model EnergyDelivery {
  id                    String    @id @default(cuid())
  depositId             String    @unique @map("deposit_id")
  userId                String    @map("user_id")
  tronAddress           String    @map("tron_address")
  totalTransactions     Int       @map("total_transactions")
  deliveredTransactions Int       @default(0) @map("delivered_transactions")
  lastEnergyCheck       DateTime? @map("last_energy_check")
  lastDeliveryAt        DateTime? @map("last_delivery_at")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deposit               Deposit   @relation(fields: [depositId], references: [id])
  user                  User      @relation(fields: [userId], references: [id])

  @@index([userId, tronAddress, isActive])
  @@index([lastEnergyCheck])
  @@map("energy_deliveries")
}

model ProcessedTransaction {
  id             String   @id @default(cuid())
  txHash         String   @unique @map("tx_hash")
  depositId      String   @map("deposit_id")
  address        String
  amountUsdt     Decimal  @map("amount_usdt") @db.Decimal(18, 6)
  blockNumber    BigInt   @map("block_number")
  blockTimestamp DateTime @map("block_timestamp")
  processedAt    DateTime @default(now()) @map("processed_at")

  @@index([depositId])
  @@index([address])
  @@index([blockTimestamp])
  @@index([processedAt])
  @@map("processed_transactions")
}

model EnergyMonitoringLog {
  id             String          @id @default(cuid())
  userId         String?         @map("user_id")
  tronAddress    String          @map("tron_address")
  action         String
  logLevel       String          @default("INFO") @map("log_level")
  energyBefore   Int?            @map("energy_before")
  energyAfter    Int?            @map("energy_after")
  energyDelta    Int?            @map("energy_delta")
  txHash         String?         @map("tx_hash")
  apiResponse    Json?           @map("api_response")
  apiDurationMs  Int?            @map("api_duration_ms")
  decisionReason String?         @map("decision_reason")
  errorMessage   String?         @map("error_message")
  errorStack     String?         @map("error_stack")
  metadata       Json?
  cycleId        String?         @map("cycle_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  energyState    UserEnergyState @relation(fields: [tronAddress], references: [tronAddress], onDelete: Cascade, map: "MonitorLogOnAddress")
  user           User?           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tronAddress])
  @@index([action])
  @@index([logLevel])
  @@index([cycleId])
  @@index([createdAt])
  @@map("energy_monitoring_logs")
}

model EnergyDelegationAudit {
  id                        String                     @id @default(cuid())
  tronAddress               String                     @map("tron_address")
  userId                    String?                    @map("user_id")
  cycleId                   String                     @map("cycle_id")
  operationType             EnergyOperationType        @map("operation_type")
  txHash                    String?                    @map("tx_hash")
  timestamp                 DateTime                   @default(now())
  energyBefore              Int?                       @map("energy_before")
  energyAfter               Int?                       @map("energy_after")
  energyDelta               Int?                       @map("energy_delta")
  reclaimedSun              BigInt?                    @map("reclaimed_sun")
  reclaimedTrx              Decimal?                   @map("reclaimed_trx") @db.Decimal(18, 6)
  reclaimedEnergy           Int?                       @map("reclaimed_energy")
  delegatedSun              BigInt?                    @map("delegated_sun")
  delegatedTrx              Decimal?                   @map("delegated_trx") @db.Decimal(18, 6)
  delegatedEnergy           Int?                       @map("delegated_energy")
  pendingTransactionsBefore Int                        @map("pending_transactions_before")
  pendingTransactionsAfter  Int                        @map("pending_transactions_after")
  transactionDecrease       Int                        @default(0) @map("transaction_decrease")
  relatedUsdtTxHash         String?                    @map("related_usdt_tx_hash")
  hasActualTransaction      Boolean                    @default(false) @map("has_actual_transaction")
  isSystemIssue             Boolean                    @default(false) @map("is_system_issue")
  issueType                 String?                    @map("issue_type")
  metadata                  Json?
  createdAt                 DateTime                   @default(now()) @map("created_at")

  @@index([tronAddress])
  @@index([cycleId])
  @@index([operationType])
  @@index([isSystemIssue])
  @@index([timestamp])
  @@index([hasActualTransaction])
  @@map("energy_delegation_audit")
}

enum DepositStatus {
  PENDING
  CONFIRMED
  PROCESSED
  FAILED
  EXPIRED
  CANCELLED
}

enum AddressStatus {
  FREE
  ASSIGNED
  USED
}

enum TransactionType {
  DEPOSIT
  CREDIT
  ENERGY_TRANSFER
  ENERGY_RECEIVED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum EnergyUserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum EnergyAllocationAction {
  DELEGATE
  TOP_UP
  RECLAIM
  PENALTY
  USAGE_DETECT
  OVERRIDE
  DELEGATE_131K
  TOP_UP_65K
  RECLAIM_FULL
  RECLAIM_PARTIAL
  PENALTY_24H
  TX_DECREMENT
  BUFFER_OK
  SKIP_LOCK_HELD
  AUDIT_CORRECTION
  ADMIN_SET_TRANSACTIONS
}

model TransactionPackage {
  id                String    @id @default(cuid())
  numberOfTxs       Int       @unique @map("number_of_txs")
  usdtCost          Decimal   @map("usdt_cost") @db.Decimal(18, 6)
  isActive          Boolean   @default(true) @map("is_active")
  description       String?
  createdBy         String    @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("transaction_packages")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum EnergyOperationType {
  RECLAIM
  DELEGATE
  RECHARGE
}

// Network parameters cache for accurate energy calculations
// Stores totalEnergyWeight and totalEnergyLimit fetched from TRON network
// Used to calculate exact TRX needed for target energy amounts
model NetworkParameters {
  id                   String   @id @default(cuid())
  totalEnergyWeight    BigInt   @map("total_energy_weight") // Network-wide TRX staked for energy
  totalEnergyLimit     BigInt   @map("total_energy_limit") // Always 180,000,000,000
  totalBandwidthWeight BigInt?  @map("total_bandwidth_weight") // Network-wide TRX staked for bandwidth
  totalBandwidthLimit  BigInt?  @map("total_bandwidth_limit") // Always 43,200,000,000
  energyPerTrx         Float    @map("energy_per_trx") // Calculated: totalEnergyLimit / totalEnergyWeight
  bandwidthPerTrx      Float?   @map("bandwidth_per_trx") // Calculated: totalBandwidthLimit / totalBandwidthWeight
  fetchedAt            DateTime @default(now()) @map("fetched_at")
  network              String   @default("mainnet") // mainnet or testnet

  @@index([network, fetchedAt(sort: Desc)])
  @@map("network_parameters")
}
