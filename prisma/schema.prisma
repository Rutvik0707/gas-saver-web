// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  passwordHash            String    @map("password_hash")
  tronAddress             String?   @unique @map("tron_address") // Made optional for account-verification
  phoneNumber             String?   @unique @map("phone_number")
  isPhoneVerified         Boolean   @default(false) @map("is_phone_verified")
  isEmailVerified         Boolean   @default(false) @map("is_email_verified")
  otpCode                 String?   @map("otp_code")
  otpExpiry               DateTime? @map("otp_expiry")
  credits                 Decimal   @default(0) @db.Decimal(18, 6)
  isActive                Boolean   @default(true) @map("is_active")
  verificationToken       String?   @map("verification_token")
  verificationTokenExpiry DateTime? @map("verification_token_expiry")
  resetToken              String?   @map("reset_token")
  resetTokenExpiry        DateTime? @map("reset_token_expiry")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  // Relations
  deposits      Deposit[]
  transactions  Transaction[]
  feedbacks     Feedback[]

  @@map("users")
}

model Deposit {
  id                  String      @id @default(cuid())
  userId              String      @map("user_id")
  assignedAddressId   String?     @map("assigned_address_id")
  assignedAddress     String      @map("assigned_address")
  txHash              String?     @unique @map("tx_hash")
  amountUsdt          Decimal?    @map("amount_usdt") @db.Decimal(18, 6)
  expectedAmount      Decimal     @map("expected_amount") @db.Decimal(18, 6)
  status              DepositStatus @default(PENDING)
  confirmed           Boolean     @default(false)
  blockNumber         BigInt?     @map("block_number")
  processedAt         DateTime?   @map("processed_at")
  expiresAt           DateTime    @map("expires_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // Relations
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressPool         AddressPool? @relation(fields: [assignedAddressId], references: [id], onDelete: SetNull)

  @@index([assignedAddress])
  @@index([expiresAt])
  @@index([status])
  @@map("deposits")
}

model AddressPool {
  id                    String      @id @default(cuid())
  address               String      @unique
  privateKeyEncrypted   String      @map("private_key_encrypted")
  status                AddressStatus @default(FREE)
  assignedToDepositId   String?     @map("assigned_to_deposit_id")
  assignedAt            DateTime?   @map("assigned_at")
  expiresAt             DateTime?   @map("expires_at")
  lastUsedAt            DateTime?   @map("last_used_at")
  usageCount            Int         @default(0) @map("usage_count")
  createdAt             DateTime    @default(now()) @map("created_at")

  // Relations
  deposits              Deposit[]

  @@index([status])
  @@index([expiresAt])
  @@index([assignedToDepositId])
  @@map("address_pool")
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String          @map("user_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(18, 6)
  txHash        String?         @map("tx_hash")
  status        TransactionStatus @default(PENDING)
  fromAddress   String?         @map("from_address")
  toAddress     String?         @map("to_address")
  description   String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  rating    Int?     // optional: if you want a 1–5 star type thing
  createdAt DateTime @default(now())
}

enum DepositStatus {
  PENDING
  CONFIRMED
  PROCESSED
  FAILED
  EXPIRED
}

enum AddressStatus {
  FREE
  ASSIGNED
  USED
}

enum TransactionType {
  DEPOSIT
  CREDIT
  ENERGY_TRANSFER
  ENERGY_RECEIVED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Admin {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String      @map("password_hash")
  name            String?
  role            AdminRole   @default(ADMIN)
  permissions     String[]    @default([])
  isActive        Boolean     @default(true) @map("is_active")
  lastLoginAt     DateTime?   @map("last_login_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}