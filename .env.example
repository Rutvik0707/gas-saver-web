# Gas Saver API - Environment Configuration
#
# IMPORTANT: This project supports two environments:
# 1. Development (devcoins) - Uses Shasta testnet with test USDT
# 2. Production (livecoins) - Uses TRON mainnet with real USDT
#
# To run different environments:
# - npm run devcoins    (uses .env.development - Shasta testnet)
# - npm run livecoins   (uses .env.production - TRON mainnet)
#
# WARNING: Never use mainnet private keys in development!
# WARNING: Always verify network configuration before running in production!

# Application
NODE_ENV=development  # Use 'production' for mainnet
PORT=3000
API_VERSION=v1

# Database
# Use different database names for dev and production to prevent data mixing
DATABASE_URL="postgresql://username:password@localhost:5432/energy_broker_dev?schema=public"  # dev
# DATABASE_URL="postgresql://username:password@localhost:5432/energy_broker_prod?schema=public"  # production

# JWT
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters-required-for-security
JWT_EXPIRES_IN=24h

# TRON Network Configuration
# For Development (Shasta Testnet) - use with: npm run devcoins
TRON_NETWORK=testnet
TRON_FULL_NODE=https://api.shasta.trongrid.io
TRON_SOLIDITY_NODE=https://api.shasta.trongrid.io
TRON_EVENT_SERVER=https://api.shasta.trongrid.io
USDT_CONTRACT_ADDRESS=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs  # Shasta testnet USDT

# For Production (TRON Mainnet) - use with: npm run livecoins
# TRON_NETWORK=mainnet
# TRON_FULL_NODE=https://api.trongrid.io
# TRON_SOLIDITY_NODE=https://api.trongrid.io
# TRON_EVENT_SERVER=https://api.trongrid.io
# USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t  # Mainnet USDT (TRC-20)

# TRON Private Keys - CRITICAL: Use different keys for testnet and mainnet!
TRON_PRIVATE_KEY=your-tron-private-key-here-64-characters
TRON_ADDRESS=your-tron-address-here-starts-with-T

# System Wallet (for receiving deposits)
SYSTEM_WALLET_ADDRESS=your-system-wallet-address-starts-with-T
SYSTEM_WALLET_PRIVATE_KEY=your-system-wallet-private-key-64-characters

# TronGrid API Key (Optional but recommended)
TRON_API_KEY=your-trongrid-api-key-here

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Settings (for admin system)
DEFAULT_ADMIN_EMAIL=admin@energybroker.com
DEFAULT_ADMIN_PASSWORD=admin123456
ENCRYPTION_SECRET=your-encryption-secret-key-minimum-32-characters-required-for-aes-256

# Email Configuration (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Gas Saver

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Energy Configuration
# Base energy required for a USDT transfer (TRC-20)
USDT_TRANSFER_ENERGY_BASE=65500
# Additional buffer percentage for safety (20% = 0.2)
ENERGY_BUFFER_PERCENTAGE=0.2
# Energy price in SUN (1 energy = X sun)
ENERGY_PRICE_SUN=420
# Minimum energy to delegate
MIN_ENERGY_DELEGATION=65500
# Maximum energy to delegate per transaction
MAX_ENERGY_DELEGATION=150000

# Pricing Configuration
# Cache TTL for live price data in milliseconds (60000 = 1 minute)
PRICE_CACHE_TTL_MS=60000
# Fallback USDT price in USD (used when API is unavailable)
FALLBACK_USDT_PRICE=1.0
# Fallback TRX price in USD (used when API is unavailable)
FALLBACK_TRX_PRICE=0.12
# Service discount percentage (15 = 15% discount)
SERVICE_DISCOUNT_PERCENTAGE=15

# Address Pool Configuration
# Cooldown period in hours before a used address can be reused (default: 1 hour)
ADDRESS_COOLDOWN_HOURS=1
