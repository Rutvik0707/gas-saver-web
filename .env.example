# Gas Saver API - Environment Configuration Example
# Copy this file to .env and fill in the appropriate values for your environment
# WARNING: Never commit actual .env files with real secrets to version control!

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/gassaver?schema=public"

# ============================================================================
# JWT Authentication
# ============================================================================
# Secret key for JWT token signing (minimum 32 characters for security)
JWT_SECRET=your-secret-key-here-minimum-32-characters-required-for-security
# JWT token expiration time (e.g., "24h", "7d")
JWT_EXPIRES_IN=24h

# ============================================================================
# TRON Network Configuration
# ============================================================================
# Network: "testnet" or "mainnet"
# WARNING: Use testnet for development, mainnet for production only!
TRON_NETWORK=testnet

# TRON API Endpoints
# Testnet:
#   TRON_FULL_NODE=https://api.shasta.trongrid.io
#   TRON_SOLIDITY_NODE=https://api.shasta.trongrid.io
#   TRON_EVENT_SERVER=https://api.shasta.trongrid.io
# Mainnet:
#   TRON_FULL_NODE=https://api.trongrid.io
#   TRON_SOLIDITY_NODE=https://api.trongrid.io
#   TRON_EVENT_SERVER=https://api.trongrid.io
TRON_FULL_NODE=https://api.shasta.trongrid.io
TRON_SOLIDITY_NODE=https://api.shasta.trongrid.io
TRON_EVENT_SERVER=https://api.shasta.trongrid.io

# TRON Private Key (for signing transactions)
# WARNING: Keep this secure! Never share or commit this to version control!
# Generate with: npm run generate-keys
TRON_PRIVATE_KEY=your-tron-private-key-here

# TRON Address associated with the private key above
TRON_ADDRESS=your-tron-address-here

# TronGrid API Key (optional but recommended for rate limit increases)
TRON_API_KEY=your-trongrid-api-key-here

# ============================================================================
# USDT Contract Configuration
# ============================================================================
# USDT (TRC-20) contract address
# Testnet: TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# Mainnet: TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t (same contract)
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# ============================================================================
# System Wallet Configuration
# ============================================================================
# System wallet address (used for receiving deposits and delegating energy)
SYSTEM_WALLET_ADDRESS=your-system-wallet-address-here

# System wallet private key (for energy delegation transactions)
# WARNING: Keep this secure! This account needs to have TRX for bandwidth and energy
# Must be different from or same as TRON_PRIVATE_KEY depending on your setup
SYSTEM_WALLET_PRIVATE_KEY=your-system-wallet-private-key-here

# ============================================================================
# TronScan API Configuration
# ============================================================================
# TronScan API for blockchain verification (optional)
TRONSCAN_API_URL=https://apilist.tronscanapi.com/api
TRONSCAN_API_KEY=your-tronscan-api-key-here

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# ============================================================================
# Rate Limiting
# ============================================================================
# Rate limiting window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Maximum number of requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# Admin Settings
# ============================================================================
# Default admin account email (used for system initialization)
DEFAULT_ADMIN_EMAIL=admin@energybroker.com
# Default admin password (CHANGE THIS IMMEDIATELY IN PRODUCTION!)
DEFAULT_ADMIN_PASSWORD=change-this-password-immediately

# ============================================================================
# Encryption Configuration
# ============================================================================
# Secret key for encrypting sensitive data (minimum 32 characters)
# Used for encrypting private keys stored in the address pool
ENCRYPTION_SECRET=your-encryption-secret-key-here-minimum-32-characters-required-for-aes-256

# ============================================================================
# Email Configuration (for password reset notifications)
# ============================================================================
# SMTP Server Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Gmail: Use app-specific password, not your regular password
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Gas Saver

# ============================================================================
# Frontend Configuration
# ============================================================================
# Frontend URL (used in password reset links and CORS configuration)
# Development: http://localhost:3001
# Production: https://your-production-domain.com
FRONTEND_URL=http://localhost:3001

# ============================================================================
# Energy Configuration
# ============================================================================
# Base energy required for a USDT transfer (TRC-20)
# Typical value: 65500
USDT_TRANSFER_ENERGY_BASE=65500

# Additional energy buffer percentage (0.2 = 20%)
# This ensures sufficient energy for transactions
ENERGY_BUFFER_PERCENTAGE=0.2

# Energy price in SUN (1 energy = X sun)
# Typical value on testnet: 420
ENERGY_PRICE_SUN=420

# Minimum energy to delegate per user
MIN_ENERGY_DELEGATION=65500

# Maximum energy to delegate per transaction
MAX_ENERGY_DELEGATION=150000

# ============================================================================
# Address Pool Configuration
# ============================================================================
# Cooldown period in hours before a used address can be reused
# This prevents address conflicts and allows proper cleanup
ADDRESS_COOLDOWN_HOURS=1

# ============================================================================
# Telegram Bot Configuration (Optional)
# ============================================================================
# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Telegram Bot Username
TELEGRAM_BOT_USERNAME=your-bot-username

# ============================================================================
# Additional Configuration
# ============================================================================
# Add any other environment variables your application needs below:
